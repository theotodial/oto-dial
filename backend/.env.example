# Primary Atlas URI (SRV). If you get querySrv ECONNREFUSED on Windows/VPN, do not force public DNS
# unless you set MONGO_DNS_USE_PUBLIC=true on purpose.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# Optional: standard URI (mongodb://host1:27017,host2:27017/...) — skips SRV DNS; use when SRV fails.
# MONGODB_URI_DIRECT=
# MONGO_DNS_USE_PUBLIC=false
# MONGO_DISABLE_DOH=true   # Disable SRV/TXT resolution fallback (Windows PowerShell + DoH)
# MONGO_DOH_USE_SYSTEM_PROXY=true   # Use HTTP(S)_PROXY for DoH if fetch must go through corporate proxy
PORT=5000
# Bind address for reverse proxy (nginx → 127.0.0.1:PORT). Use 0.0.0.0 in production unless you intentionally isolate.
HOST=0.0.0.0

# Telnyx WebRTC (outbound SIP) — required for /api/webrtc/token
# TELNYX_API_KEY=...
# TELNYX_CONNECTION_ID=...   # Credential connection ID
# TELNYX_SIP_USERNAME=...    # Must match the credential connection username
# TELNYX_SIP_PASSWORD=...    # Credential connection password (returned to the logged-in client for TelnyxRTC)
# Inbound voice routing (recommended): use a dedicated inbound connection id (Call Control / TeXML app).
# TELNYX_INBOUND_CONNECTION_ID=...
# Legacy fallback (not recommended): if true, number provisioning/fix routes may reuse TELNYX_CONNECTION_ID for inbound.
# TELNYX_ALLOW_OUTBOUND_CONNECTION_FOR_INBOUND=false
# Outbound repair sync (default true): set false only if you intentionally want to prevent caller-number connection sync.
# TELNYX_SYNC_CALLER_CONNECTION_ID=true
# When TELNYX_SIP_PASSWORD is set, the server does not mint telephony JWTs (SIP-only WebRTC auth).
# Optional: TELNYX_TELEPHONY_CREDENTIAL_ID + TELNYX_USE_TELEPHONY_JWT=true to also mint JWT alongside SIP.
# If +1-8xx toll-free fails with EXCHANGE_ROUTING_ERROR: try
# TELNYX_MERGE_OUTBOUND_WHITELIST=US,uitf
# or force the list: TELNYX_REPLACE_OUTBOUND_WHITELIST=US,CA,uitf

# Telnyx phone number monthly rental used for admin cost dashboards ($2/number/mo default).
# TELNYX_NUMBER_MONTHLY_USD=2
# TELECOM_SAME_COUNTRY_OUTBOUND_ONLY=true
# Optional: comma-separated ISO2 codes for Telnyx messaging profile when international mode is on (defaults to all countries listed in backend country catalog).
# TELNYX_MESSAGING_WHITELIST_DESTINATIONS=PK,JP,GB,DE,IN,US,CA
# Outbound SMS: use Telnyx POST /messages/long_code so the owned +E.164 number is the sender (avoids messaging profile default alphanumeric IDs on international routes). Set false only if Telnyx support directs you to the generic send path.
# SMS_USE_TELNYX_LONG_CODE_ENDPOINT=true

# Optional call-flow debugging (do not enable in production unless isolating issues)
# CALL_DEBUG_SKIP_SUBSCRIPTION=true   # Skip active-subscription check on POST /api/calls only
# Emergency stabilization: skip profit throttle, telecom policy, fraud delay on POST /api/calls (keep auth/subscription/credits)
# CALL_MINIMAL_MODE=true
# Force real projected-credit + reserve/attempt billing on local (overrides localhost auto-bypass)
# CALL_DEBUG_FORCE_REAL_BILLING=true
# Explicit: allow outbound POST without credit ledger (non-production only; redundant if FRONTEND_URL is localhost)
# CALL_DEBUG_ALLOW_OUTBOUND_WITHOUT_CREDITS=true  # Opt-in only — skips all outbound credit charges (non-production)
# CALL_DEBUG_FORCE_REAL_BILLING=true            # Force real billing even when debug bypass is set
# CALL_AUDIT_FAILED_ATTEMPTS=true    # Insert failed Call rows when outbound validation rejects
# CALL_DEBUG_AUTH_LOG=true           # Log [AUTH CHECK] on every authenticated route

# Resend email service (production: verify otodial.com in Resend)
RESEND_API_KEY=REPLACE_WITH_NEW_KEY
# From header — must be a verified domain in Resend (quote if the value contains spaces):
RESEND_FROM="OTODIAL <no-reply@otodial.com>"
# Optional Reply-To header (defaults to info@otodial.com in code if unset)
# RESEND_REPLY_TO=info@otodial.com
# SPA origin (redirects after email verification, password reset links). Use localhost:3000 in dev with Vite.
FRONTEND_URL=https://otodial.com
# Public marketing / app URL fallback when FRONTEND_URL is unset.
APP_URL=https://otodial.com
# REQUIRED when the API is on a different host than the SPA (e.g. api.otodial.com). Verification emails link here: {BACKEND_URL}/api/auth/verify-email
# BACKEND_URL=https://api.otodial.com
# Delay (ms) before one-time “choose your plan” email after signup when user has no subscription (default 120000)
# PRICING_ONBOARDING_EMAIL_DELAY_MS=120000
# Optional: recipient for GET /api/test-email (debug Resend)
# TEST_EMAIL_TO=you@yourdomain.com
STRIPE_WEBHOOK_SECRET_EMAIL=REPLACE_WITH_NEW_SECRET

# Google Analytics 4 — OTO DIAL stream (https://www.otodial.com)
GA4_MEASUREMENT_ID=G-X3WN8RYCQ5
GA4_PROPERTY_ID=523626440
# Path to Google service account JSON (standard GOOGLE_APPLICATION_CREDENTIALS)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-service-account.json
# Or inline JSON / base64 / email+key — see googleAnalyticsService.js
# Create in GA4 Admin > Data Streams > OTO DIAL > Measurement Protocol API secrets
GA4_MP_API_SECRET=
GA4_ENABLED=true
GA4_DEBUG=false
GA4_RECONCILE_ENABLED=true
GA4_RECONCILE_INTERVAL_MS=300000

# Redis (optional — enables distributed cache, locks, live intel sync, campaign queue)
# Redis Cloud: copy the redis-cli -u URL from the console (often redis:// for public endpoint)
# REDIS_URL=redis://default:PASSWORD@your-instance.db.redis.io:PORT