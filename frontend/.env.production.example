# Production build (Vite): copy to .env.production on the build host if needed.
#
# Recommended when the API is served on the SAME origin as the SPA (Nginx → /api → Node):
#   leave VITE_API_URL unset OR set exactly:
#   VITE_API_URL=https://otodial.com
#
# If the API is on a separate hostname (e.g. api.otodial.com), set the full origin:
#   VITE_API_URL=https://api.otodial.com
#
# Must match server env for OAuth and links:
#   APP_URL / FRONTEND_URL / BACKEND_URL → https://otodial.com (see backend env validator)

VITE_API_URL=https://otodial.com

# Optional. In production do not use values under ~45000 — WebRTC token/repair-outbound can exceed 5s easily.
# VITE_API_TIMEOUT_MS=90000
# Match backend CALL_MINIMAL_MODE — skip client repair-outbound after dial (rebuild SPA after changing)
# VITE_CALL_MINIMAL_MODE=true

# Google Analytics 4 (client-side — Measurement Protocol secret stays on backend only)
VITE_GA4_MEASUREMENT_ID=G-X3WN8RYCQ5
# Production default: enabled when building for production. Set false to disable.
# VITE_GA4_ENABLED=true
# VITE_GA4_DEBUG=false
